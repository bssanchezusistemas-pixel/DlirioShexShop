# URL pública del sitio (producción). Usada en sitemap, Open Graph y SEO.
NEXT_PUBLIC_SITE_URL=https://dlirio-shex-shop.vercel.app

# Código de verificación de Google Search Console (meta tag HTML)
# Obtener en: Search Console → Configuración → Verificación → Etiqueta HTML
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Solo servidor — NUNCA exponer al cliente ni commitear
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Emails con acceso al panel admin (separados por coma)
ADMIN_EMAILS=admin@example.com

# Solo para scripts/fix-admin-auth.mjs (crear o resetear usuario admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password
